   "source": [
    "nums = [3,2,4]\n",
    "target = 6\n",
    "\n",
    "seen = {}\n",
    "temp = 0\n",
    "\n",
    "for i, num in enumerate(nums):\n",
    "    temp = target - num\n",
    "\n",
    "    if temp in seen:\n",
    "        print(f\"{seen[temp]},{i}\")\n",
    "\n",
    "    seen[num] = i\n"
   ],
